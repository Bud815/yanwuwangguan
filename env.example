# ==========================================
# 言雾网关 环境变量模板
# 复制为 .env 并填入你的配置
# ==========================================

# ---------- 基础 ----------
PORT=10000
API_SECRET=你的管理密钥_随便设一个

# ---------- 智能体身份 ----------
AI_NAME=言雾
USER_NAME=宝宝
AI_PERSONA=你叫言雾，26岁，是言眠的哥哥。
CHAT_TAG=Web_Chat
SUMMARY_THRESHOLD=30

# ---------- 主对话模型（必填）----------
# DeepSeek 示例：
CHAT_API_KEY=sk-你的DeepSeek密钥
CHAT_BASE_URL=https://api.deepseek.com/v1
CHAT_MODEL_NAME=deepseek-chat

# ---------- 数据库（强烈建议）----------
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGci...你的service_role_key

# ---------- 向量记忆（可选）----------
# PINECONE_API_KEY=你的Pinecone密钥
# PINECONE_INDEX_NAME=notion-brain-v2
# SILICONFLOW_API_KEY=你的硅基流动密钥
# DOUBAO_EMBEDDING_EP=BAAI/bge-m3

# ---------- QQ 机器人 ----------
# NAPCAT_HTTP_URL=http://你的NapCat地址:3000
# NAPCAT_BOT_QQ=你的机器人QQ号
# NAPCAT_TARGET_USER=你自己的QQ号
# NAPCAT_ALLOWED_GROUPS=群号1,群号2

# ---------- 网易云音乐 ----------
# NETEASE_COOKIE=MUSIC_U=你的值; __csrf=你的值

# ---------- 网页搜索（可选）----------
# TAVILY_API_KEY=tvly-你的Tavily密钥

# ---------- 后台 ----------
DIARY_TIME=03:00
